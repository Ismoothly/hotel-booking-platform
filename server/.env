# 服务器配置
NODE_ENV=development
PORT=5000

# MongoDB 配置
# 本地开发环境
#MONGODB_URI=mongodb://localhost:27017/hotel-booking-dev
MONGODB_URI=mongodb://admin:admin123@localhost:27017/hotel-booking-dev?authSource=admin
# MongoDB Atlas 云端配置（可选）
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/hotel-booking?retryWrites=true&w=majority

# 用于测试环境的单独数据库
# MONGODB_TEST_URI=mongodb://localhost:27017/hotel-booking-test

# CORS 配置
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# JWT 配置
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_this_in_production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# 日志级别
LOG_LEVEL=debug
